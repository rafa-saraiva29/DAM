<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.CoolWeatherApp" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="android:windowBackground">@drawable/bg_light_portrait</item>

        <item name="colorPrimary">@color/my_light_primary</item>
        <item name="colorSecondary">@color/my_light_secondary</item>

        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/my_light_primary</item>
    </style>

    <style name="Theme.Day" parent="Theme.CoolWeatherApp">
        <item name="colorPrimary">@color/my_light_primary</item>
        <item name="colorSecondary">@color/my_light_secondary</item>
    </style>

    <style name="Theme.Day.Land" parent="Theme.CoolWeatherApp">
        <item name="android:windowBackground">@drawable/bg_light_land</item>
    </style>


</resources>